# ===========================================
# Sturdy Waddle PM — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# ---- Database ----
DATABASE_URL=postgresql://waddle:waddle@localhost:5432/waddle_pm
DATABASE_URL_TEST=postgresql://waddle:waddle@localhost:5432/waddle_pm_test

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
AUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ---- AI / OpenAI ----
OPENAI_API_KEY=sk-your-openai-key

# ---- S3 / File Storage ----
S3_BUCKET=waddle-pm-files
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- Application ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
LOG_LEVEL=debug
